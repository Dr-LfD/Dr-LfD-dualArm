# Copy to `.env` and `source .env` (or export these in your shell) before
# running. Config files reference these via ${VAR} placeholders, expanded by
# repo_paths.load_yaml(). Unset variables are left literal and fail loudly.

# Generic workspace root for non-repo data dirs only (e.g. dataset paths in
# .vscode/launch.json args). NOT used for code repos -- each repo gets its own
# macro below.
export WS_ROOT=/path/to/your/workspace

# External dependency repos -- one dedicated macro per repo (set the absolute
# path of your checkout; no default, so an unset one fails loudly).
export GROUNDED_SAM2_ROOT=/path/to/Grounded-SAM-2               # open-world segmentation (sam_path)
export SAM3_ROOT=/path/to/sam3                                  # SAM3 segmentation (sam3_path)
export ACT_ROOT=/path/to/ALOHA/act                             # ACT policy (ACT_path)
export RIEMANN_SEG_ROOT=/path/to/RiEMann_seg                    # equivariant grasp segmentation
export PRIMITIVE_LEARNING_ROOT=/path/to/equiv_primitive_abstract        # object-centric primitive learning
export DIFFUSION_POLICY_ROOT=/path/to/Diffusion-Policy          # visuomotor policies (+ checkpoints under data/outputs)
export SPHERICAL_DP_ROOT=/path/to/Spherical_Diffusion_Policy    # spherical diffusion policy (SDP configs)
export DEXMIMICGEN_ROOT=/path/to/dexmimicgen                    # sim env / data (env_dir)
export CONTACT_PREDICTION_ROOT=/path/to/contact_prediction      # real-robot contact prediction

# SAM3 model weights cache (defaults to the standard modelscope location).
export SAM3_MODEL_DIR=${HOME}/.cache/modelscope/hub/models/facebook/sam3

# Python interpreter of the isolated conda env used for equivariant grasping,
# invoked via subprocess by openworld_aloha/grasp/utils.py.
export EQUI_PYTHON=${HOME}/miniforge3/envs/equi/bin/python
