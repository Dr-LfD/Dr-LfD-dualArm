# Copy to `.env` and `source .env` (or export these in your shell) before
# running. Config files reference these via ${VAR} placeholders, expanded by
# repo_paths.load_yaml(). Unset variables are left literal and fail loudly.

# Workspace root holding the external dependency repositories below as siblings.
# Set it so the paths in the configs resolve, e.g. ${WS_ROOT}/Diffusion-Policy.
export WS_ROOT=/path/to/your/workspace

# Expected (clone/install separately) under or near ${WS_ROOT}:
#   Grounded-SAM-2            -> referenced as ${WS_ROOT}/Grounded-SAM-2
#   sam3                      -> ${WS_ROOT}/sam3
#   equibot_abstract          -> ${WS_ROOT}/equibot_abstract   (DiffGen data/policy)
#   ContactPrediction         -> ${WS_ROOT}/ContactPrediction
#   Diffusion-Policy          -> ${WS_ROOT}/.../Diffusion-Policy
#   dexmimicgen               -> ${WS_ROOT}/.../dexmimicgen     (env_dir / data)
#   ALOHA/act                 -> ${WS_ROOT}/.../ALOHA/act       (ACT policy)
# Adjust the configs' sub-paths to match your actual layout under ${WS_ROOT}.

# SAM3 model weights cache (defaults to the standard modelscope location).
export SAM3_MODEL_DIR=${HOME}/.cache/modelscope/hub/models/facebook/sam3

# Python interpreter of the isolated conda env used for equivariant grasping,
# invoked via subprocess by openworld_aloha/grasp/utils.py.
export EQUI_PYTHON=${HOME}/miniforge3/envs/equi/bin/python
